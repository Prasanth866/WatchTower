DATABASE_URL=postgresql+asyncpg://user:change_me_in_prod@postgres:5432/mydb
REDIS_URL=redis://redis:6379
SECRET_KEY=replace_with_a_strong_secret_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SQLALCHEMY_ECHO=false

RESEND_API_KEY=re_your_resend_api_key_here
