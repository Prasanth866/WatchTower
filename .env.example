REDIS_URL=redis://redis:6379
SECRET_KEY=replace_with_a_strong_secret_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SQLALCHEMY_ECHO=false

